{
	"manifest_version": 2,
	"name": "YouTube Feed Bookmark",
	"version": "0.5.0",
	"description": "Mark videos on the YouTube feed as bookmarks to easily identify new uploads.",
	"author": "MrWhiteHat",
	"permissions": [
		"storage",
		"https://www.youtube.com/*"
	],
	"icons": {
		"48": "icons/icon48.png",
		"96": "icons/icon96.png"
	},
	"browser_action": {
		"default_icon": {
			"48": "icons/icon48.png",
			"96": "icons/icon96.png"
		},
		"default_title": "YouTube Feed Bookmark",
		"default_popup": "popup.html"
	},
	"content_scripts": [
		{
			"matches": [
				"https://www.youtube.com/feed/subscriptions*"
			],
			"js": [
				"content.js"
			],
			"css": [
				"content.css"
			],
			"run_at": "document_idle"
		}
	],
	"web_accessible_resources": [
		"icons/*.svg"
	],
	"browser_specific_settings": {
		"gecko": {
			"id": "yt-feed-bookmark",
			"strict_min_version": "109.0",
			"update_url": "https://github.com/mwareslicer/yt-feed-bookmark/raw/master/updates.json"
		}
	}
}
